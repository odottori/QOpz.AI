# ── Virtual env & cache ───────────────────────────────────────────────────────
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/

# ── Runtime data (montati come volumi) ────────────────────────────────────────
db/
logs/
ops/
reports/

# ── Frontend — inclusa nel build nginx multi-stage ───────────────────────────
# ui/ è necessaria per Dockerfile.nginx (stage ui-builder)
# Escludi solo node_modules e dist per tenere il context leggero
ui/node_modules/
ui/dist/

# ── Test & dev ────────────────────────────────────────────────────────────────
tests/
planner/
samples/
.quarantine/
.canonici/

# ── Git & temp ────────────────────────────────────────────────────────────────
.git/
.gitignore
.tmp/
.tmp_test/

# ── Windows artifacts ─────────────────────────────────────────────────────────
*.bat
*.ps1

# ── Docs & config vari ───────────────────────────────────────────────────────
AGENTS.md
CLAUDE.md
*.lock
validator.py
